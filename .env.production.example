# Railway Production Environment Variables
# Copy these to Railway Dashboard → Variables

# ============================================
# APPLICATION
# ============================================
NODE_ENV=production
PORT=3000
API_PREFIX=api/v1

# ============================================
# DATABASE (Railway auto-provides these)
# ============================================
# Railway injects: PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE
# You can use these or set custom values
DB_HOST=${PGHOST}
DB_PORT=${PGPORT}
DB_USERNAME=${PGUSER}
DB_PASSWORD=${PGPASSWORD}
DB_NAME=${PGDATABASE}
DB_SYNC=false  # ⚠️ NEVER set to true in production!
DB_LOGGING=false  # Set to true only for debugging

# ============================================
# REDIS (Add Redis service in Railway)
# ============================================
REDIS_HOST=${REDIS_HOST}
REDIS_PORT=${REDIS_PORT}
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_TTL=3600

# ============================================
# JWT AUTHENTICATION
# ⚠️ CRITICAL: Generate secure secrets!
# Run: openssl rand -base64 32
# ============================================
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_32_CHARS
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_SECURE_RANDOM_STRING_32_CHARS
JWT_REFRESH_EXPIRATION=7d

# ============================================
# CORS
# ⚠️ IMPORTANT: Update with your actual domains
# ============================================
CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============================================
# FILE UPLOAD & STORAGE
# ============================================
STORAGE_PROVIDER=local
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# ============================================
# AWS S3 (Only if STORAGE_PROVIDER=s3)
# ============================================
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=medium-clone-uploads

# ============================================
# PAGINATION
# ============================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info  # Use 'warn' or 'error' for less verbosity

# ============================================
# EMAIL (Optional - for future features)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@medium-clone.com

# ============================================
# NOTES
# ============================================
# 1. Railway auto-injects database variables from PostgreSQL service
# 2. Generate JWT secrets: openssl rand -base64 32
# 3. Never commit secrets to git
# 4. Update CORS_ORIGINS with your actual domains
# 5. Test health check: GET /api/v1/health
